# npm policy settings. Applies to all sub-packages via npm's upward .npmrc
# resolution. Rationale and threat model in docs/security/npm-policy.md.

# Refuse to install if the declared Node engine doesn't match. Prevents
# accidental installs on a Node version we haven't tested against.
engine-strict=true

# Fail `npm install` / `npm ci` if known vulnerabilities at moderate or
# higher severity are present in the resolved tree.
audit-level=moderate

# Newly added direct deps are pinned to exact versions, not caret ranges.
# Combined with package-lock.json, this means upgrades are deliberate.
save-exact=true

# NOTE: deeper supply-chain protections (minimum-release-age, per-package
# install-script allowlists) require pnpm. Migrating this repo to pnpm
# surfaced undeclared transitive deps (xaip-sdk imports `zod` without
# declaring it, hidden by npm's permissive hoisting). That migration is
# tracked as a separate workstream — see docs/security/npm-policy.md.
